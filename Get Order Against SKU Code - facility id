    -- PURCHASE ORDERS
    SELECT
        ''PURCHASE ORDER'',
        po.code,
        po.status_code,
        itype.sku_code,
        NULL,
        poi.quantity,
        NULL,
        CONCAT(''Received: '', poi.received_quantity, '' | Vendor: '', po.vendor_id),
