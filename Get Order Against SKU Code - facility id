      AND grn.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

    UNION ALL

    -- SALE ORDERS
    SELECT
        ''SALE ORDER'',
        so.code,
        so.status_code,
        soi.sku_code,
        NULL,
        soi.quantity,
        NULL,
        CONCAT(''Item status: '', soi.status_code, '' | Channel: '', so.channel_id),
        NULL,
        NULL,
        soi.created,
        fac.display_name
    FROM ', @schema_name, '.sale_order_item soi
    JOIN ', @schema_name, '.sale_order so ON soi.sale_order_id = so.id
    JOIN ', @schema_name, '.facility fac ON fac.id = soi.facility_id
    WHERE soi.sku_code = ''', @sku_code, '''
      AND soi.facility_id = ', @facility_id, '
      AND soi.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

