    -- GATEPASS via Inventory Adjustment
    SELECT
        ''GATEPASS (ADJ)'',
        adj.remarks,
        adj.adjustment_type,
        adj.sku_code,
        adj.old_quantity,
        adj.quantity,
        NULL,
        CONCAT(''by='', adj.username),
        NULL,
        NULL,
        adj.created,
        fac.display_name
    FROM ', @schema_name, '.inventory_adjustment adj
    JOIN ', @schema_name, '.facility fac ON fac.id = adj.facility_id
    WHERE adj.sku_code = ''', @sku_code, '''
      AND adj.facility_id = ', @facility_id, '
      AND (adj.adjustment_type LIKE ''%GATEPASS%'' OR adj.remarks LIKE ''%GP%'' OR adj.remarks LIKE ''%GATEPASS%'')
      AND adj.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

    UNION ALL

    -- GRN / PURCHASE
    SELECT
        ''GRN / PURCHASE'',
        grn.code,
        grn.status_code,
        itype.sku_code,
        NULL,
        grn_item.quantity,
        NULL,
        CONCAT(''invoice='', grn.vendor_invoice_number, '' | date='', grn.vendor_invoice_date),
        grn.vendor_invoice_number,
        grn_item.rejected_quantity,
        grn.created,
        fac.display_name
    FROM ', @schema_name, '.inflow_receipt grn
    JOIN ', @schema_name, '.inflow_receipt_item grn_item ON grn_item.inflow_receipt_id = grn.id
    JOIN ', @schema_name, '.item_type itype ON itype.id = grn_item.item_type_id
    JOIN ', @schema_name, '.facility fac ON fac.id = grn.facility_id
    WHERE itype.sku_code = ''', @sku_code, '''
