        NULL,
        pui.created,
        fac.display_name
    FROM ', @schema_name, '.putaway_item pui
    JOIN ', @schema_name, '.putaway p ON pui.putaway_id = p.id
    JOIN ', @schema_name, '.item_type itype ON pui.item_type_id = itype.id
    JOIN ', @schema_name, '.facility fac ON fac.id = p.facility_id
    WHERE itype.sku_code = ''', @sku_code, '''
      AND p.facility_id = ', @facility_id, '
      AND pui.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

    UNION ALL

    -- CYCLE COUNT SETTLEMENT
    SELECT
        ''CYCLE COUNT SETTLEMENT'',
        CONCAT(''CC-'', ccs.source_cycle_count_task_id),
        ccs.type,
        itype.sku_code,
        NULL,
        ccs.quantity,
        NULL,
        CONCAT(''Settled: '', ccs.settled, '' | Settled qty: '', ccs.settled_quantity),
