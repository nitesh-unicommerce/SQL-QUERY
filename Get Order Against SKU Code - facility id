        NULL,
        poi.created,
        fac.display_name
    FROM ', @schema_name, '.purchase_order_item poi
    JOIN ', @schema_name, '.purchase_order po ON poi.purchase_order_id = po.id
    JOIN ', @schema_name, '.item_type itype ON poi.item_type_id = itype.id
    JOIN ', @schema_name, '.facility fac ON fac.id = po.facility_id
    WHERE itype.sku_code = ''', @sku_code, '''
      AND po.facility_id = ', @facility_id, '
      AND poi.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

    UNION ALL

    -- PUTAWAY
    SELECT
        ''PUTAWAY'',
        p.code,
        pui.status_code,
        itype.sku_code,
        NULL,
        pui.quantity,
        NULL,
        CONCAT(''Shelf: '', pui.shelf_id, '' | Type: '', pui.type),
