        itype.sku_code,
        NULL,
        invs.quantity,
        NULL,
        CONCAT(''Blocked: '', invs.quantity_blocked, '' | Settled: '', invs.settled),
        NULL,
        NULL,
        invs.created,
        fac.display_name
    FROM ', @schema_name, '.inventory_settlement invs
    JOIN ', @schema_name, '.item_type itype ON invs.item_type_id = itype.id
    JOIN ', @schema_name, '.facility fac ON fac.id = invs.facility_id
    WHERE itype.sku_code = ''', @sku_code, '''
      AND invs.facility_id = ', @facility_id, '
      AND invs.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

    UNION ALL

    -- OUTBOUND GATE PASS
    SELECT
        ''OUTBOUND GATE PASS'',
        ogp.code,
        ogp.status_code,
        itype.sku_code,
        NULL,
        ogpi.quantity,
        NULL,
        CONCAT(''To party: '', ogp.to_party_id, '' | Type: '', ogp.type),
        NULL,
        NULL,
        ogp.created,
        fac.display_name
    FROM ', @schema_name, '.outbound_gate_pass ogp
    JOIN ', @schema_name, '.outbound_gate_pass_item ogpi ON ogp.id = ogpi.outbound_gate_pass_id
    JOIN ', @schema_name, '.item_type itype ON ogpi.item_type_id = itype.id
    JOIN ', @schema_name, '.facility fac ON fac.id = ogp.facility_id
    WHERE itype.sku_code = ''', @sku_code, '''
      AND ogp.facility_id = ', @facility_id, '
      AND ogp.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

) AS combined_result
ORDER BY event_time ASC;
');

-- 2. Unfulfillable analysis – shows orders that were NOT fully fulfilled
SET @sql_unfulfilled = CONCAT('
SELECT 
    so.id AS sale_order_id,
    so.code AS order_code,
    soi.id AS order_item_id,
    soi.sku_code,
    soi.quantity AS ordered_qty,
    soi.status_code AS item_status,
    so.status_code AS order_status,
    soi.cancellation_reason,
    soi.cancelled_by_seller,
    soi.created AS order_date,
    -- Check if inventory allocation existed
    (SELECT COUNT(*) FROM ', @schema_name, '.item_type_inventory_allocation itia 
     WHERE itia.sale_order_item_id = soi.id) AS allocation_entries,
    -- Check if any picklist item was created
    (SELECT COUNT(*) FROM ', @schema_name, '.picklist_item pli 
     WHERE pli.sale_order_item_code = soi.code) AS picklist_items,
    -- If allocation exists but no picklist, likely inventory shortage
    CASE 
        WHEN soi.status_code IN (''CANCELLED'', ''FAILED'', ''ON_HOLD'') THEN ''Order item not fulfilled''
        WHEN soi.quantity > (SELECT IFNULL(SUM(ita.quantity),0) FROM ', @schema_name, '.item_type_inventory_allocation ita WHERE ita.sale_order_item_id = soi.id)
             THEN ''Partially allocated – insufficient inventory''
        WHEN soi.status_code = ''PENDING'' AND (SELECT COUNT(*) FROM ', @schema_name, '.picklist_item pli WHERE pli.sale_order_item_code = soi.code) = 0
             THEN ''Never picked – allocation or workflow issue''
        ELSE ''Fulfilled or in progress''
    END AS unfulfillable_reason
FROM ', @schema_name, '.sale_order_item soi
JOIN ', @schema_name, '.sale_order so ON so.id = soi.sale_order_id
WHERE soi.sku_code = ''', @sku_code, '''
  AND soi.facility_id = ', @facility_id, '
  AND soi.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''
  AND (soi.status_code != ''DELIVERED'' OR soi.quantity > (SELECT IFNULL(SUM(ita.quantity),0) FROM ', @schema_name, '.item_type_inventory_allocation ita WHERE ita.sale_order_item_id = soi.id))
ORDER BY soi.created DESC;
');

