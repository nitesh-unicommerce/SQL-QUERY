SET @sql_detailed = CONCAT('
SELECT * FROM (
    -- GATEPASS via Inventory Ledger
    SELECT
        ''GATEPASS'' AS event_type,
        ledger.transaction_identifier AS reference_code,
        ledger.transaction_type,
        ledger.sku_code,
        ledger.old_balance,
        ledger.quantity,
        ledger.new_balance,
        ledger.additional_info AS remarks,
        NULL AS vendor_invoice,
        NULL AS rejected_qty,
        ledger.created AS event_time,
        fac.display_name AS facility_name
    FROM ', @schema_name, '.inventory_ledger ledger
    JOIN ', @schema_name, '.facility fac ON fac.id = ledger.facility_id
    WHERE ledger.sku_code = ''', @sku_code, '''
      AND ledger.facility_id = ', @facility_id, '
      AND ledger.transaction_type LIKE ''%GATEPASS%''
      AND ledger.created BETWEEN ''', @start_date, ''' AND ''', @end_date, '''

